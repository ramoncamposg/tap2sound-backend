# Puerto (Railway lo inyecta automaticamente; en local usa 3000)
PORT=3000

# Cadena de conexion a Postgres.
# En Railway: usa la variable de referencia ${{ Postgres.DATABASE_URL }}
# En local: postgres://USER:PASS@localhost:5432/tap2sound
DATABASE_URL=postgres://postgres:postgres@localhost:5432/tap2sound

# Secreto para firmar los JWT. Cambialo por una cadena larga y aleatoria.
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# Email del primer admin que se crea automaticamente al arrancar (opcional)
ADMIN_EMAIL=admin@tap2sound.com
ADMIN_PASSWORD=admin1234
